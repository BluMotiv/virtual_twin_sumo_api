# ──────────────────────────────────────────────────────────────
# SUMO Scenario Generation API — Environment Configuration
# ──────────────────────────────────────────────────────────────

# ── Server ──
HOST=0.0.0.0
PORT=8000
DEBUG=false
LOG_LEVEL=INFO

# ── Open-Meteo (no key required) ──
OPEN_METEO_FORECAST_URL=https://api.open-meteo.com/v1/forecast
OPEN_METEO_ARCHIVE_URL=https://archive-api.open-meteo.com/v1/archive
OPEN_METEO_GEOCODE_URL=https://geocoding-api.open-meteo.com/v1/search
OPEN_METEO_TIMEOUT=15

# ── Elevation (Open-Meteo built-in or open-elevation) ──
OPEN_ELEVATION_URL=https://api.open-elevation.com/api/v1/lookup

# ── SUMO output directory ──
SUMO_OUTPUT_DIR=output/sumo

# ── ML Models root directory ──
ML_MODELS_DIR=mlmodels/MODELS

# ── Forecast window (days) — beyond this, use ML models ──
FORECAST_WINDOW_DAYS=10

# ── Cache TTL (seconds) ──
CACHE_TTL=3600
